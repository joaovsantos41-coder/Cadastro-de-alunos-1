#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <stdbool.h>
#include <locale.h>
#include <unistd.h>
#include <ctype.h>

#define max 50

// Variáveis Globais
int op = 0, sop = 0, ida = 0, idc = 0, idt = 0, idm = 0;
char resp;

struct aluno {
    char pk_cpf[15];
    char nome[max];
    char admissao[11];
    char dtNasc[11];
    char escolaridade[max];
};

struct curso {
    int pk_codCurso;
    char nome[max];
    int cargaHoraria;
    char modalidade[20];
};

struct turma {
    int pk_codTurma;
    char nomeTurma[max];
    int qtdAlunos;
    char turno[20];
};

struct matricula {
    int pk_ra;
    char fk_cpf[15];
    int fk_codTurma;
    int fk_codCurso;
};

// Vetores de armazenamento
struct aluno tbaluno[max];
struct curso tbcurso[max];
struct turma tbturma[max];
struct matricula tbmatricula[max];

// ============================================================================
// FUNÇÕES DE VALIDAÇÃO
// ============================================================================
int validarCPF(char cpf[]) {
    if (strlen(cpf) != 14) return 0;
    if (cpf[3] != '.' || cpf[7] != '.' || cpf[11] != '-') return 0;
    return 1;
}

int validarData(char data[]) {
    if (strlen(data) != 10) return 0;
    if (data[2] != '/' || data[5] != '/') return 0;
    return 1;
}

void limparBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

// ============================================================================
// FUNÇÕES DE BUSCA (Retornam o índice no vetor ou -1 se não encontrar)
// ============================================================================
int obter_idx_aluno(char cpf[15]) {
    for (int i = 0; i < ida; i++) {
        if (strcmp(tbaluno[i].pk_cpf, cpf) == 0) return i;
    }
    return -1;
}

int obter_idx_curso(int codCurso) {
    for (int i = 0; i < idc; i++) {
        if (tbcurso[i].pk_codCurso == codCurso) return i;
    }
    return -1;
}

int obter_idx_turma(int codTurma) {
    for (int i = 0; i < idt; i++) {
        if (tbturma[i].pk_codTurma == codTurma) return i;
    }
    return -1;
}

int obter_idx_matricula(int ra) {
    for (int i = 0; i < idm; i++) {
        if (tbmatricula[i].pk_ra == ra) return i;
    }
    return -1;
}

// ============================================================================
// FUNÇÕES DE VERIFICAÇÃO DE CHAVE ESTRANGEIRA (Para Exclusão)
// ============================================================================
bool matricula_vinculada_aluno(char cpf[]) {
    for (int i = 0; i < idm; i++) {
        if (strcmp(tbmatricula[i].fk_cpf, cpf) == 0) return true;
    }
    return false;
}

bool matricula_vinculada_curso(int codCurso) {
    for (int i = 0; i < idm; i++) {
        if (tbmatricula[i].fk_codCurso == codCurso) return true;
    }
    return false;
}

bool matricula_vinculada_turma(int codTurma) {
    for (int i = 0; i < idm; i++) {
        if (tbmatricula[i].fk_codTurma == codTurma) return true;
    }
    return false;
}

